# Kopieer dit bestand naar .env.local en vul de waarden in (lokaal).
# Op Vercel: zet dezelfde keys in Project Settings > Environment Variables (Production + Preview).

# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-...

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://orspplwyquwyoczwtgmu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # SERVER-ONLY, nooit naar client

# === E-mail via Strato SMTP (intake-uitnodiging + notificatie) ===
# De intake-mails (magic link naar de klant + notificatie naar Eva) lopen via
# Strato SMTP (nodemailer). Het From-adres MOET het geauthenticeerde postvak zijn.
SMTP_HOST=smtp.strato.de
SMTP_PORT=465                       # 465 = SSL (aanbevolen), 587 = STARTTLS
SMTP_USER=Info@praktijkdenieuweweelde.nl
SMTP_PASS=                          # wachtwoord van het Strato-postvak
# Optioneel: afwijkend From-adres. Standaard: "Relatiepraktijk de Nieuwe Weelde <SMTP_USER>"
SMTP_FROM=
# Ontvanger van de "nieuwe intake"-notificatie. Valt terug op MAIL_TO, dan SMTP_USER.
EVA_EMAIL=Info@praktijkdenieuweweelde.nl
MAIL_TO=Info@praktijkdenieuweweelde.nl

# === Intake-formulier (magic link) ===
# Basis-URL voor de magic links (geen trailing slash). Lokaal: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.praktijkdenieuweweelde.nl
# Geldigheid van een intake-uitnodiging in dagen (optioneel, standaard 14).
INTAKE_INVITE_EXPIRY_DAYS=14
